# Copy this file to .env and fill in real values. Never commit .env.

# ========================
# DATABASE (PostgreSQL — required, no SQLite fallback)
# ========================
# Local development (PostgreSQL managed via pgAdmin):
DATABASE_URL=postgresql://postgres:<your_local_password>@localhost:5432/sana_bd
# Production (Render/Supabase): DATABASE_URL is provided automatically by
# the platform — do not hardcode it here or in settings.py.

# ========================
# DJANGO CORE
# ========================
DJANGO_SECRET_KEY=<your_secret_key>
DJANGO_DEBUG=True
# Comma-separated list of allowed hosts (production only; ignored in DEBUG)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ========================
# GEMINI AI
# ========================
GEMINI_API_KEY=

# ========================
# EMAIL (password reset, welcome email)
# Resend (RESEND_API_KEY) takes priority over SMTP when set — required in
# production since Render blocks outbound SMTP ports. Leave both blank to
# print emails to the console instead of sending them.
# ========================
RESEND_API_KEY=

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=SANA <no-reply@sana.app>

# ========================
# MEDIA STORAGE (chat photos/voice notes, journal attachments)
# Supabase Storage (S3-compatible) takes priority over the local filesystem
# when SUPABASE_S3_ENDPOINT_URL is set — required in production since
# Render's disk is wiped on every deploy. Leave blank to use the local
# filesystem (fine for local dev).
# ========================
SUPABASE_S3_ENDPOINT_URL=
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_BUCKET=media
SUPABASE_S3_REGION=us-east-1

# ========================
# VAPID (Web Push notifications)
# ========================
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_EMAIL=contact@sana.app
